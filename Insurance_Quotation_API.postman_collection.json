{
  "info": {
    "name": "Insurance Quotation Comparison API",
    "description": "Collection for testing the multi-provider insurance quotation system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"password\": \"SecurePassword123!\",\n  \"password2\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login (Get Tokens)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('access_token', jsonData.access);",
                  "    pm.environment.set('refresh_token', jsonData.refresh);",
                  "    pm.test('Tokens set in environment', function () {",
                  "        pm.expect(pm.environment.get('access_token')).to.be.a('string');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/profile/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "profile"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Quote Endpoints",
      "item": [
        {
          "name": "Get Quotes (Health Insurance)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test('Response has required fields', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('best_quote');",
                  "    pm.expect(jsonData).to.have.property('quotes');",
                  "    pm.expect(jsonData).to.have.property('comparison_summary');",
                  "});",
                  "",
                  "pm.test('Best quote is marked correctly', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.best_quote.is_best).to.be.true;",
                  "});",
                  "",
                  "pm.test('Quotes are sorted by score', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var quotes = jsonData.quotes;",
                  "    var scores = quotes.map(q => q.comparison_score);",
                  "    var sortedScores = [...scores].sort((a, b) => b - a);",
                  "    pm.expect(scores).to.eql(sortedScores);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"insurance_type\": \"health\",\n  \"age\": 30,\n  \"sum_insured\": 500000,\n  \"city\": \"Dubai\",\n  \"members\": 2,\n  \"additional_details\": {\n    \"pre_existing_conditions\": false\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/quotes/get-quotes/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "quotes",
                "get-quotes"
              ]
            }
          }
        },
        {
          "name": "Get Quotes (Travel Insurance)",
          "request": {
            "method": "POST",
